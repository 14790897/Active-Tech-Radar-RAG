---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	plan(plan)
	search(search)
	cache(cache)
	filter(filter)
	triage(triage)
	investigate(investigate)
	synthesize(synthesize)
	refine(refine)
	__end__([<p>__end__</p>]):::last
	__start__ --> plan;
	cache --> filter;
	filter --> triage;
	investigate --> synthesize;
	plan --> search;
	refine --> search;
	search --> cache;
	synthesize -.-> __end__;
	synthesize -.-> refine;
	triage --> investigate;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
